{
  "name": "af-docs",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --dir apps/docs dev",
    "dev:docker": "docker compose -f docker-compose.dev.yml up -d --build",
    "stop": "pnpm stop:docker",
    "stop:docker": "docker compose -f docker-compose.dev.yml down -v",
    "build": "turbo build --filter=docs",
    "start": "pnpm --dir apps/docs start",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "typegen": "turbo typegen",
    "postinstall": "pnpm typegen",
    "build:openapi": "turbo build:openapi",
    "build:api-doc": "turbo build:api-doc"
  },
  "devDependencies": {
    "@spellix/eslint-config": "^4.0.3",
    "eslint": "^8.56.0",
    "prettier-plugin-packagejson": "^2.5.19",
    "turbo": "^2.5.8",
    "typescript": "^5.9.2"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  }
}
